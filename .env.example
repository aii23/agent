# ─── Local dev ───────────────────────────────────────────────────────────────
# Copy to .env.local and adjust.
# When running Redis/Postgres on a remote server, replace localhost with the
# server IP and include the Redis password:
#   REDIS_URL="redis://:yourpassword@server-ip:6379"
#   DATABASE_URL="postgresql://postgres:yourpassword@server-ip:5432/praxis_agents"

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/praxis_agents"

# Redis
REDIS_URL="redis://localhost:6379"

# AI keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-google-key-here

# Optional providers
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# PERPLEXITY_API_KEY=

# Notion integration
NOTION_TOKEN=secret_your-notion-integration-token

# Auth / session
NEXTAUTH_SECRET=change-me-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# Encryption key for stored API keys in DB (32-byte hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-64-char-hex-string