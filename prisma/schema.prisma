// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AgentType {
  MANAGER
  EXECUTOR
}

enum RunStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum ExecutionPlanStatus {
  PLANNING
  EXECUTING
  SYNTHESIZING
  DONE
  FAILED
}

enum StepStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageStatus {
  PENDING
  STREAMING
  DONE
  FAILED
}

// ─────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())

  sessions      Session[]
  workflowRuns  WorkflowRun[]
  conversations Conversation[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Agents
// ─────────────────────────────────────────────

model Agent {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  role         String
  systemPrompt String
  tools        Json     @default("[]")
  model        String   @default("claude-sonnet")
  inputSchema  Json?
  outputSchema Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  description String?
  agentType   AgentType @default(EXECUTOR)
  notionScope Json?
  maxSteps    Int       @default(8)

  delegatesTo Agent[] @relation("AgentDelegation")
  delegatedBy Agent[] @relation("AgentDelegation")

  workflowSteps WorkflowStep[]
  conversations Conversation[]
}

// ─────────────────────────────────────────────
// Workflows
// ─────────────────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  steps       Json // array of step definitions
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs WorkflowRun[]
}

model WorkflowRun {
  id          String    @id @default(uuid())
  templateId  String
  triggeredBy String
  status      RunStatus @default(PENDING)
  input       Json
  output      Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  template WorkflowTemplate @relation(fields: [templateId], references: [id])
  user     User             @relation(fields: [triggeredBy], references: [id])
  steps    WorkflowStep[]
}

model WorkflowStep {
  id          String    @id @default(uuid())
  runId       String
  agentId     String
  stepIndex   Int
  status      RunStatus @default(PENDING)
  input       Json
  output      Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  run      WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agent    Agent       @relation(fields: [agentId], references: [id])
  llmCalls LlmCall[]
}

// ─────────────────────────────────────────────
// LLM Usage Tracking
// ─────────────────────────────────────────────

model LlmCall {
  id               String   @id @default(uuid())
  stepId           String?
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Decimal? @db.Decimal(10, 6)
  durationMs       Int?
  createdAt        DateTime @default(now())

  step WorkflowStep? @relation(fields: [stepId], references: [id])
}

// ─────────────────────────────────────────────
// Chat
// ─────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  agentId   String?
  title     String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages       Message[]
  executionPlans ExecutionPlan[]
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  status         MessageStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Execution Engine (chat-driven orchestration)
// ─────────────────────────────────────────────

model ExecutionPlan {
  id               String              @id @default(uuid())
  conversationId   String
  messageId        String              // triggering user Message id
  managerSlug      String
  status           ExecutionPlanStatus @default(PLANNING)
  steps            Json                // PlanStep[] — raw templates from manager LLM call
  currentStepIndex Int                 @default(0)
  managerThread    Json?               // CoreMessage[] — saved LLM thread for synthesis
  notionPageIds    String[]            @default([]) // page IDs selected by manager during planning
  notionContext    String?             // compressed Notion context injected into executor prompts
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  executionSteps ExecutionStep[]
}

model ExecutionStep {
  id              String     @id @default(uuid())
  executionPlanId String
  stepIndex       Int
  agentSlug       String
  resolvedPrompt  String
  output          String?
  status          StepStatus @default(PENDING)
  createdAt       DateTime   @default(now())
  completedAt     DateTime?

  plan ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)

  @@unique([executionPlanId, stepIndex])
}

// ─────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────

model NotionConnection {
  id            String   @id @default(uuid())
  accessToken   String // encrypted at application layer
  workspaceId   String   @unique
  workspaceName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Cached Notion page index — populated by lib/notion-index.ts sync
model NotionPage {
  id           String   @id                   // Notion page ID
  title        String
  path         String                          // breadcrumb: "Strategy / Q3 / OKRs"
  summary      String                          // 1-2 sentence LLM-generated summary
  isEmpty      Boolean  @default(false)        // true when raw content is blank — excluded from context
  parentId     String?                         // parent page ID, if any
  databaseId   String?                         // parent database ID, if a DB row
  lastEditedAt DateTime                        // from Notion last_edited_time
  syncedAt     DateTime @default(now())        // our last successful sync
  raw          String?  @db.Text               // full plain-text content, refreshed on demand

  @@index([databaseId])
  @@index([isEmpty])
  @@index([lastEditedAt])
  @@index([syncedAt])
}

model ProviderConfig {
  id           String   @id @default(uuid())
  provider     String   @unique // e.g. "openai", "anthropic"
  encryptedKey String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
