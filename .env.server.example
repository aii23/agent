# ─── Server environment file (.env.server) ───────────────────────────────────
# Copy to .env.server on your server and fill in real values.
# Used by docker-compose.yml — never commit the real file.

# Passwords (used by docker-compose service definitions AND the worker)
REDIS_PASSWORD=change-me-strong-redis-password
POSTGRES_PASSWORD=change-me-strong-postgres-password

# AI provider keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-google-key-here

# Optional providers
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# PERPLEXITY_API_KEY=

# Auth / session
NEXTAUTH_SECRET=change-me-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# Notion OAuth (if used)
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_REDIRECT_URI=

# Encryption key for stored API keys in DB (32-byte hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-64-char-hex-string
TAVILY_KEY=